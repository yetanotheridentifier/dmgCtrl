      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "Sessions by city",
          "description": "Sessions per city plotted by approximate location (Cloudflare edge PoP coordinates)",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "afltq9th19d6ob"
                      },
                      "spec": {
                        "dataset": "iox",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT country, city, AVG(latitude) AS latitude, AVG(longitude) AS longitude, COUNT(DISTINCT \"sessionId\") AS sessions\nFROM events\nWHERE env = '$env'\n  AND city != 'unknown'\n  AND latitude IS NOT NULL\n  AND $__timeFilter(time)\nGROUP BY country, city\nORDER BY sessions DESC\nLIMIT 100"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "geomap",
            "version": "13.1.0-25668120414",
            "spec": {
