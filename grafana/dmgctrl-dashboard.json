                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT 'SWU' AS game, COUNT(*) AS games\nFROM events\nWHERE env = '$env'\n  AND event = 'game_started'\n  AND $__timeFilter(time)\nUNION ALL\nSELECT 'X-Wing' AS game, COUNT(*) AS games\nFROM events\nWHERE env = '$env'\n  AND event = 'xwing_game_started'\n  AND $__timeFilter(time)\nORDER BY games DESC"
