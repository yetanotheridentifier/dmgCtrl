                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  ROUND(100.0 * COUNT(DISTINCT CASE WHEN event IN ('game_started', 'xwing_game_started') THEN \"sessionId\" END) / NULLIF(COUNT(DISTINCT \"sessionId\"), 0), 1) AS \"Started a game\",\n  ROUND(100.0 * COUNT(DISTINCT CASE WHEN event = 'undo_used' THEN \"sessionId\" END) / NULLIF(COUNT(DISTINCT CASE WHEN event IN ('game_started', 'xwing_game_started') THEN \"sessionId\" END), 0), 1) AS \"Undo used\",\n  ROUND(100.0 * COUNT(DISTINCT CASE WHEN event = 'app_resumed' THEN \"sessionId\" END) / NULLIF(COUNT(DISTINCT \"sessionId\"), 0), 1) AS \"Returned to app\"\nFROM events\nWHERE env = '$env' AND $__timeFilter(time)"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
