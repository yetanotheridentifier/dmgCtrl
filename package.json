{
  "name": "dmgctrl",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --host",
    "dev:sealed": "npm --prefix sealed run dev",
    "dev:all": "bash scripts/dev-sealed.sh",
    "build": "tsc -b && vite build",
    "build:github": "vite build --mode github",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && npm --prefix proxy test && npm --prefix sealed test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.3",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-plugin-mkcert": "^2.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
